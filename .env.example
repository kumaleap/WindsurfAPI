# ========== Server ==========
PORT=3001
# API key for incoming requests (leave empty for open access)
API_KEY=
# Dashboard password (single password, backward compatible)
DASHBOARD_PASSWORD=
# Optional extra dashboard passwords, comma-separated
DASHBOARD_PASSWORDS=

# ========== Codeium Auth ==========
# Option 1: Direct API key from Windsurf
CODEIUM_API_KEY=

# Option 2: Token from windsurf.com/show-auth-token
CODEIUM_AUTH_TOKEN=

# ========== Language Server ==========
# Path to language_server_linux_x64 binary
LS_BINARY_PATH=/opt/windsurf/language_server_linux_x64
# gRPC port for language server
LS_PORT=42100

# ========== Advanced ==========
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-haiku
MAX_TOKENS=8192
LOG_LEVEL=info

# Conservative defaults for Trial / shared account pools.
RPM_LIMIT_TRIAL=4
MAX_INFLIGHT_TRIAL=1
# Trial accounts should avoid high-cost Anthropic models by default. 1 allows Haiku-like models;
# raise only for confirmed paid Pro accounts that still report "Trial".
MAX_TRIAL_ANTHROPIC_CREDIT=1
RPM_LIMIT_PRO=20
MAX_INFLIGHT_PRO=2
MAX_UPSTREAM_ATTEMPTS=2
# Leave empty to disable real model canaries; metadata-only GetUserStatus still runs.
# Set explicitly only when debugging model entitlement, e.g. PROBE_CANARIES=gpt-4o-mini,gemini-2.5-flash
PROBE_CANARIES=
ENABLE_EXPENSIVE_PROBE=false
ENABLE_CASCADE_PREWARM=false
MAX_CONTEXT_CHARS=180000
MAX_TOOL_RESULT_CHARS=64000
MAX_CONTEXT_MESSAGES=200
